ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# RN 0.85's prebuilt React Native Core binary (default since RCT_USE_PREBUILT_RNCORE
# defaults to '1') fails to link against our heavyweight C++ static lib (RNLlamaCpp.a
# pulls in libc++ exceptions/RTTI/regex/deque via nlohmann::json, jinja, llama.cpp
# common code, etc.) — undefined libc++ runtime symbols (__cxa_throw, std::runtime_error,
# ...) at the final app link step. Build React Native Core from source instead.
ENV['RCT_USE_PREBUILT_RNCORE'] = '0'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'llamarnexample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )


  # Run Codegen during development for the example app.
  pre_install do |installer|
    system("cd ../../ && npx bob build --target codegen")
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # fmt 11.x uses consteval for compile-time format string checking. Apple Clang 21
    # (Xcode 26) rejects this even in C++20 mode. Compiling fmt in C++17 mode makes
    # consteval unavailable at the language level, so FMT_CONSTEVAL falls back to
    # constexpr and all format_to/FMT_STRING calls compile cleanly.
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end
    end
  end
end
